# Angle One Smart API Configuration
# Get API Key from Angel One Smart API portal
VITE_ANGLEONE_API_KEY=your_api_key_here

# Your Angel One trading client code (username)
VITE_ANGLEONE_CLIENT_CODE=your_client_code_here

# TOTP Secret Key from Angel One (32-character UUID format)
# This is used to generate TOTP for 2FA authentication (same as Google Authenticator)
VITE_ANGLEONE_TOTP_SECRET=your_totp_secret_here

# Use proxy server for API calls (recommended for development)
# Set to 'false' only if using a backend that handles CORS
# Default: 'true' (uses proxy)
VITE_USE_PROXY=true
